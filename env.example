import { useState, useEffect } from 'react';
import { Search, Target, Calendar, Plus, X, AlertTriangle } from 'lucide-react';
import { Card, Button, Input, cn } from '../components/ui';
import { motion, AnimatePresence } from 'framer-motion';
import { useAuthStore } from '../store/authStore';
import { useLangStore } from '../store/langStore';
import { db } from '../lib/db';

const CATEGORIES_RU = ['Все', 'Промышленность', 'Экология', 'Технологии', 'Строительство'];
const CATEGORIES_EN = ['All', 'Industry', 'ESG', 'Technology', 'Real Estate'];

const CAT_DB_MAP: Record<string, string> = {
  'Все': 'Все', 'Промышленность': 'Промышленность', 'Экология': 'Экология', 'Технологии': 'Технологии', 'Строительство': 'Строительство',
  'All': 'Все', 'Industry': 'Промышленность', 'ESG': 'Экология', 'Technology': 'Технологии', 'Real Estate': 'Строительство'
};

const CAT_RU_TO_EN: Record<string, string> = {
  'Все': 'All', 'Промышленность': 'Industry', 'Экология': 'ESG', 'Технологии': 'Technology', 'Строительство': 'Real Estate'
};

const CAT_EN_TO_RU: Record<string, string> = {
  'All': 'Все', 'Industry': 'Промышленность', 'ESG': 'Экология', 'Technology': 'Технологии', 'Real Estate': 'Строительство'
};

export const Projects = () => {
  const { user, updateUser } = useAuthStore();
  const { lang, t } = useLangStore();
  const [projects, setProjects] = useState<any[]>([]);
  const [activeCatDisplay, setActiveCatDisplay] = useState(lang === 'ru' ? 'Все' : 'All');
  const [searchQuery, setSearchQuery] = useState('');
  const [investingProject, setInvestingProject] = useState<any>(null);
  const [amount, setAmount] = useState('');
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [isLoading, setIsLoading] = useState(true);
  const [showCreateModal, setShowCreateModal] = useState(false);
  const [newProject, setNewProject] = useState({
    title: '', title_en: '', category: 'Промышленность',
    min_investment: '', target_amount: '', roi_annual: '',
    duration_months: '', description: '', description_en: '',
    image_url: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=800'
  });

  const currentCategories = lang === 'ru' ? CATEGORIES_RU : CATEGORIES_EN;

  useEffect(() => {
    setActiveCatDisplay(lang === 'ru' ? (CAT_EN_TO_RU[activeCatDisplay] || 'Все') : (CAT_RU_TO_EN[activeCatDisplay] || 'All'));
  }, [lang]);

  useEffect(() => { fetchProjects(); }, [lang]);

  const fetchProjects = async () => {
    setIsLoading(true);
    try {
      const res = await db.execute('SELECT * FROM projects');
      const mapped = res.rows
        .filter((row: any) => row.status === 'active' || row.status === 'paused')
        .map((row: any) => ({
          id: row.id,
          title: String(row.title || ''),
          title_en: String(row.title_en || row.title || ''),
          category: String(row.category || ''),
          minInvestment: Number(row.min_investment || 0),
          targetAmount: Number(row.target_amount || 0),
          collectedAmount: Number(row.collected_amount || 0),
          roi: Number(row.roi_annual || 0),
          duration: Number(row.duration_months || 0),
          shortDescription: String(row.description || ''),
          shortDescriptionEn: String(row.description_en || row.description || ''),
          longDescription: String(row.description || ''),
          longDescriptionEn: String(row.description_en || row.description || ''),
          image: String(row.image_url || 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800'),
          status: String(row.status || 'active'),
          investors: 0
        }));
      setProjects(mapped);
    } catch (err) { console.error(err); } finally { setIsLoading(false); }
  };

  const activeCategoryDb = CAT_DB_MAP[activeCatDisplay] || 'Все';

  const filteredProjects = projects.filter(p =>
    (activeCategoryDb === 'Все' || p.category === activeCategoryDb) &&
    (lang === 'ru' ? p.title : p.title_en).toLowerCase().includes(searchQuery.toLowerCase())
  );

  const handleCreateProject = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!user) return;
    setIsSubmitting(true);
    try {
      const id = 'p_f_' + Math.random().toString(36).substring(2, 9);
      await db.execute({
        sql: 'INSERT INTO projects (id, title, title_en, category, min_investment, target_amount, roi_annual, duration_months, description, description_en, image_url, status) VALUES (?,?,?,?,?,?,?,?,?,?,?,?)',
        args: [id, newProject.title, newProject.title_en, newProject.category,
          parseFloat(newProject.min_investment), parseFloat(newProject.target_amount),
          parseFloat(newProject.roi_annual), parseInt(newProject.duration_months),
          newProject.description, newProject.description_en, newProject.image_url, 'active']
      });
      setShowCreateModal(false);
      fetchProjects();
      alert(lang === 'ru' ? 'Проект создан!' : 'Project created!');
    } catch (err) { console.error(err); alert(lang === 'ru' ? 'Ошибка' : 'Error'); }
    finally { setIsSubmitting(false); }
  };

  const handleInvest = async () => {
    if (!user || !investingProject) return;
    const numAmount = parseFloat(amount);
    if (isNaN(numAmount) || numAmount < investingProject.minInvestment) {
      alert(`${t('minInvestLabel')}: €${investingProject.minInvestment}`); return;
    }
    if (numAmount > user.balance) { alert(t('insufficient')); return; }
    setIsSubmitting(true);
    try {
      const iId = Math.random().toString(36).substring(2, 15);
      const txId = Math.random().toString(36).substring(2, 15);
      await db.execute({ sql: 'INSERT INTO investments (id, user_id, project_id, amount, status) VALUES (?,?,?,?,?)', args: [iId, user.id, investingProject.id, numAmount, 'active'] });
      await db.execute({ sql: 'UPDATE users SET balance = ? WHERE id = ?', args: [user.balance - numAmount, user.id] });
      await db.execute({ sql: 'INSERT INTO transactions (id, user_id, type, amount, status, details) VALUES (?,?,?,?,?,?)', args: [txId, user.id, 'investment', numAmount, 'completed', `${t('investedIn')} ${investingProject.title}`] });
      updateUser({ balance: user.balance - numAmount });
      setInvestingProject(null); setAmount('');
      alert(t('confirm'));
    } catch (err) { console.error(err); alert(t('error')); }
    finally { setIsSubmitting(false); }
  };

  const displayTitle = (p: any) => lang === 'ru' ? p.title : (p.title_en || p.title);
  const displayDesc = (p: any) => lang === 'ru' ? p.shortDescription : (p.shortDescriptionEn || p.shortDescription);
  const displayLongDesc = (p: any) => lang === 'ru' ? p.longDescription : (p.longDescriptionEn || p.longDescription);
  const displayCat = (cat: string) => lang === 'ru' ? cat : (CAT_RU_TO_EN[cat] || cat);

  return (
    <div className="space-y-8 animate-in fade-in duration-500">
      <div className="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
          <h1 className="text-3xl font-bold text-white">{t('projects')}</h1>
          <p className="text-[#94A3B8]">{t('explore')}</p>
        </div>
        <div className="flex flex-col md:flex-row gap-4">
          <div className="relative w-full md:w-80">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-[#64748B] w-4 h-4" />
            <input placeholder={t('search')} value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="w-full h-12 bg-[#1E293B]/60 border border-[#334155] rounded-xl pl-11 pr-4 text-white focus:outline-none focus:border-[#38BDF8] transition-all" />
          </div>
          {(user?.role === 'founder' || user?.role === 'admin') && (
            <Button className="h-12" onClick={() => setShowCreateModal(true)}>
              <Plus className="w-4 h-4 mr-2" /> {t('createProject')}
            </Button>
          )}
        </div>
      </div>

      <div className="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
        {currentCategories.map((cat) => (
          <button key={cat} onClick={() => setActiveCatDisplay(cat)}
            className={cn("px-6 py-2.5 rounded-full text-sm font-semibold whitespace-nowrap transition-all",
              activeCatDisplay === cat ? "bg-[#38BDF8] text-white shadow-lg" : "bg-[#1E293B] text-[#94A3B8] hover:bg-[#334155] hover:text-white")}
          >{cat}</button>
        ))}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        {filteredProjects.map((project, idx) => {
          const progress = (project.collectedAmount / project.targetAmount) * 100;
          return (
            <motion.div key={project.id} initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: idx * 0.1 }}>
              <Card className="p-0 overflow-hidden group border-white/5 hover:border-[#38BDF8]/40 transition-all">
                <div className="h-56 relative overflow-hidden">
                  <img src={project.image} alt={displayTitle(project)} className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                  <div className="absolute inset-0 bg-gradient-to-t from-[#0A0C15] to-transparent" />
                  <div className="absolute bottom-4 left-4">
                    <span className="bg-[#38BDF8] text-white text-[10px] font-bold px-2 py-1 rounded uppercase">{displayCat(project.category)}</span>
                  </div>
                  <div className="absolute top-4 right-4 bg-black/40 backdrop-blur-md text-white text-[10px] font-bold px-2 py-1 rounded border border-white/10">{project.roi}% {t('roi')}</div>
                </div>
                <div className="p-6 space-y-6">
                  <div>
                    <h3 className="text-lg font-bold text-white mb-2 group-hover:text-[#38BDF8] transition-colors">{displayTitle(project)}</h3>
                    <p className="text-[#94A3B8] text-sm mb-4 line-clamp-2">{displayDesc(project)}</p>
                    <div className="flex items-center gap-4 text-sm text-[#94A3B8]">
                      <div className="flex items-center gap-1.5"><Target className="w-4 h-4" /> {t('minInvestLabel')}: €{project.minInvestment}</div>
                      <div className="flex items-center gap-1.5"><Calendar className="w-4 h-4" /> {project.duration} {t('months')}</div>
                    </div>
                  </div>
                  <div className="space-y-3">
                    <div className="flex justify-between text-sm">
                      <span className="text-[#94A3B8]">{t('collected')} <span className="text-white font-bold">€{project.collectedAmount.toLocaleString()}</span></span>
                      <span className="text-[#94A3B8]">{t('targetAmount')}: €{project.targetAmount.toLocaleString()}</span>
                    </div>
                    <div className="w-full h-2 bg-[#1E293B] rounded-full overflow-hidden">
                      <motion.div initial={{ width: 0 }} animate={{ width: `${progress}%` }} className="h-full bg-gradient-to-r from-[#38BDF8] to-[#818CF8]" />
                    </div>
                    <div className="flex justify-between text-xs">
                      <span className="text-[#64748B]">{progress.toFixed(1)}% {t('funded')}</span>
                      <Button className="h-8 px-4 text-xs" size="sm" onClick={() => setInvestingProject(project)}>{t('invest')}</Button>
                    </div>
                  </div>
                </div>
              </Card>
            </motion.div>
          );
        })}
      </div>

      <AnimatePresence>
        {investingProject && (
          <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={() => setInvestingProject(null)} className="absolute inset-0 bg-black/80 backdrop-blur-sm" />
            <motion.div initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }} className="relative w-full max-w-md">
              <Card className="p-8 border-[#38BDF8]/30">
                <button onClick={() => setInvestingProject(null)} className="absolute top-6 right-6 text-[#64748B] hover:text-white"><X size={24} /></button>
                <h2 className="text-xl font-bold text-white mb-2">{t('invest')}</h2>
                <p className="text-[#38BDF8] text-sm font-semibold mb-4">{displayTitle(investingProject)}</p>
                <div className="bg-[#0F111A] border border-[#334155] rounded-xl p-4 mb-6"><p className="text-[#94A3B8] text-xs leading-relaxed">{displayLongDesc(investingProject)}</p></div>
                <div className="space-y-6">
                  <div className="bg-[#1E293B]/50 rounded-2xl p-4 flex justify-between">
                    <div><p className="text-[10px] text-[#64748B] uppercase mb-1">{t('yourBalance')}</p><p className="text-lg font-bold text-white">€{user?.balance.toLocaleString()}</p></div>
                    <div className="text-right"><p className="text-[10px] text-[#64748B] uppercase mb-1">{t('minInvestLabel')}</p><p className="text-lg font-bold text-[#38BDF8]">€{investingProject.minInvestment}</p></div>
                  </div>
                  <Input label={t('investAmount')} type="number" value={amount} onChange={(e) => setAmount(e.target.value)} placeholder="0.00" />
                  {parseFloat(amount) > (user?.balance || 0) && <div className="bg-red-500/10 border border-red-500/20 rounded-xl p-3 text-red-400 text-sm flex items-center gap-2"><AlertTriangle size={16} /> {t('insufficient')}</div>}
                  <Button className="w-full h-12" isLoading={isSubmitting} onClick={handleInvest} disabled={!amount || parseFloat(amount) < investingProject.minInvestment || parseFloat(amount) > (user?.balance || 0)}>{t('confirm')}</Button>
                </div>
              </Card>
            </motion.div>
          </div>
        )}

        {showCreateModal && (
          <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={() => setShowCreateModal(false)} className="absolute inset-0 bg-black/80 backdrop-blur-sm" />
            <motion.div initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }} className="relative w-full max-w-2xl max-h-[90vh] overflow-y-auto">
              <Card className="p-8 border-[#38BDF8]/30">
                <button onClick={() => setShowCreateModal(false)} className="absolute top-6 right-6 text-[#64748B] hover:text-white"><X size={24} /></button>
                <h2 className="text-2xl font-bold text-white mb-6">{t('createProject')}</h2>
                <form onSubmit={handleCreateProject} className="space-y-4">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <Input label={t('titleEn')} placeholder="Project Name" value={newProject.title_en} onChange={(e) => setNewProject({...newProject, title_en: e.target.value})} required />
                    <Input label={t('titleRu')} placeholder="Название" value={newProject.title} onChange={(e) => setNewProject({...newProject, title: e.target.value})} required />
                    <div>
                      <label className="text-xs font-bold text-[#64748B] uppercase mb-2 block">{t('categoryLabel')}</label>
                      <select value={newProject.category} onChange={(e) => setNewProject({...newProject, category: e.target.value})} className="w-full h-11 bg-[#0F111A] border border-[#334155] rounded-xl px-4 text-white outline-none">
                        <option value="Промышленность">{lang === 'ru' ? 'Промышленность' : 'Industry'}</option>
                        <option value="Экология">{lang === 'ru' ? 'Экология' : 'ESG'}</option>
                        <option value="Технологии">{lang === 'ru' ? 'Технологии' : 'Technology'}</option>
                        <option value="Строительство">{lang === 'ru' ? 'Строительство' : 'Real Estate'}</option>
                      </select>
                    </div>
                    <Input label={`${t('minInvestLabel')} (€)`} type="number" value={newProject.min_investment} onChange={(e) => setNewProject({...newProject, min_investment: e.target.value})} required />
                    <Input label={`${t('targetAmount')} (€)`} type="number" value={newProject.target_amount} onChange={(e) => setNewProject({...newProject, target_amount: e.target.value})} required />
                    <Input label={`${t('roiLabel')} (%)`} type="number" value={newProject.roi_annual} onChange={(e) => setNewProject({...newProject, roi_annual: e.target.value})} required />
                    <Input label={`${t('duration')} (${t('months')})`} type="number" value={newProject.duration_months} onChange={(e) => setNewProject({...newProject, duration_months: e.target.value})} required />
                  </div>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <label className="text-xs font-bold text-[#64748B] uppercase block">{t('descEn')}</label>
                      <textarea value={newProject.description_en} onChange={(e) => setNewProject({...newProject, description_en: e.target.value})} className="w-full h-24 bg-[#0F111A] border border-[#334155] rounded-xl p-4 text-white text-xs focus:border-[#38BDF8] outline-none" required />
                    </div>
                    <div className="space-y-2">
                      <label className="text-xs font-bold text-[#64748B] uppercase block">{t('descRu')}</label>
                      <textarea value={newProject.description} onChange={(e) => setNewProject({...newProject, description: e.target.value})} className="w-full h-24 bg-[#0F111A] border border-[#334155] rounded-xl p-4 text-white text-xs focus:border-[#38BDF8] outline-none" required />
                    </div>
                  </div>
                  <Input label={t('imageUrl')} value={newProject.image_url} onChange={(e) => setNewProject({...newProject, image_url: e.target.value})} required />
                  <Button className="w-full h-12" isLoading={isSubmitting}>{t('createProject')}</Button>
                </form>
              </Card>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
};
