import { useState, useEffect } from 'react';
import { Link, useNavigate } from 'react-router-dom';
import { Mail, Lock, Eye, EyeOff, LogIn, ArrowRight, ShieldCheck, TrendingUp } from 'lucide-react';
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import * as z from 'zod';
import { motion, AnimatePresence } from 'framer-motion';
import { Button, Input, cn } from '../components/ui';
import { db } from '../lib/db';
import { useAuthStore } from '../store/authStore';

const loginSchema = z.object({
  email: z.string().email('Некорректный email'),
  password: z.string().min(1, 'Введите пароль'),
  captcha: z.string().min(4, 'Введите капчу'),
  rememberMe: z.boolean().optional()
});

type LoginForm = z.infer<typeof loginSchema>;

const GeometricBackground = () => (
  <div className="fixed inset-0 pointer-events-none overflow-hidden z-0 opacity-20">
    <motion.div animate={{ rotate: 360 }} transition={{ duration: 20, repeat: Infinity, ease: "linear" }} className="absolute -top-24 -left-24 w-96 h-96 border-2 border-[#38BDF8] rounded-[60px]" />
    <motion.div animate={{ rotate: -360 }} transition={{ duration: 25, repeat: Infinity, ease: "linear" }} className="absolute top-1/2 -right-32 w-80 h-80 border border-[#818CF8] rotate-45" />
    <motion.div animate={{ y: [0, 50, 0] }} transition={{ duration: 10, repeat: Infinity }} className="absolute bottom-20 left-1/3 w-16 h-16 bg-[#38BDF8] rounded-full blur-2xl" />
    <div className="absolute top-1/4 left-1/2 w-0.5 h-full bg-gradient-to-b from-transparent via-[#334155] to-transparent" />
  </div>
);

export const Login = () => {
  const [showPassword, setShowPassword] = useState(false);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<{ field: 'email' | 'password' | 'captcha' | 'general', message: string } | null>(null);
  const [captchaCode, setCaptchaCode] = useState('');
  
  const navigate = useNavigate();
  const { setAuth, token } = useAuthStore();

  useEffect(() => {
    if (token) {
      navigate('/dashboard');
    }
    generateCaptcha();
  }, [token, navigate]);

  const generateCaptcha = () => {
    setCaptchaCode(Math.floor(1000 + Math.random() * 9000).toString());
  };

  const { register, handleSubmit, formState: { errors } } = useForm<LoginForm>({
    resolver: zodResolver(loginSchema)
  });

  const onSubmit = async (data: LoginForm) => {
    setIsLoading(true);
    setError(null);

    if (data.captcha !== captchaCode) {
      setError({ field: 'captcha', message: 'Неверный код с картинки' });
      generateCaptcha();
      setIsLoading(false);
      return;
    }

    try {
      const res = await db.execute({
        sql: 'SELECT * FROM users WHERE email = ?',
        args: [data.email]
      });

      if (res.rows.length === 0) {
        setError({ field: 'email', message: 'Пользователь с таким email не найден' });
        setIsLoading(false);
        return;
      }

      const user = res.rows[0];

      if (user.password !== data.password) {
        setError({ field: 'password', message: 'Неверный пароль. Попробуйте еще раз' });
        setIsLoading(false);
        return;
      }

      if (user.status !== 'active') {
        setError({ field: 'general', message: 'Ваш аккаунт заблокирован или ожидает активации' });
        setIsLoading(false);
        return;
      }

      setAuth({
        id: user.id as string,
        email: user.email as string,
        full_name: user.full_name as string,
        role: user.role as any,
        status: user.status as string,
        balance: user.balance as number,
        referral_code: user.referral_code as string,
        two_fa_enabled: !!user.two_fa_enabled,
        kyc_status: user.kyc_status as string,
        loyalty_tier: 'Bronze',
        total_invested: 0,
        avatar_url: user.avatar_url as string,
        telegram_id: user.telegram_id as string,
        company_name: user.company_name as string,
        inn: user.inn as string
      }, 'mock-jwt-token');

      navigate('/dashboard');
    } catch (err: any) {
      setError({ field: 'general', message: 'Ошибка сервера. Попробуйте позже' });
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="min-h-screen w-full flex items-center justify-center bg-[#0A0C15] p-4 relative overflow-hidden">
      <GeometricBackground />
      
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        className="w-full max-w-6xl z-10 flex flex-col lg:flex-row bg-[#111827]/80 backdrop-blur-2xl border border-white/10 rounded-[40px] overflow-hidden shadow-2xl"
      >
        {/* Left Side: Info */}
        <div className="hidden lg:flex flex-col justify-between w-1/2 p-16 bg-gradient-to-br from-[#1E293B] to-[#0F111A] relative overflow-hidden">
          <div className="absolute inset-0 opacity-10">
            <div className="absolute top-0 left-0 w-full h-full" style={{ backgroundImage: 'radial-gradient(#38BDF8 1px, transparent 1px)', backgroundSize: '30px 30px' }} />
          </div>
          
          <div className="relative z-10">
            <div className="flex items-center gap-3 mb-12">
              <div className="w-12 h-12 bg-[#38BDF8] rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/40">
                <TrendingUp className="text-white w-7 h-7" />
              </div>
              <span className="text-2xl font-black text-white tracking-tighter uppercase">CapitalFlow</span>
            </div>

            <div className="space-y-8">
              <h2 className="text-5xl font-bold text-white leading-tight">Будущее индустриальных <span className="text-[#38BDF8]">инвестиций</span> уже здесь.</h2>
              <p className="text-xl text-[#94A3B8] leading-relaxed max-w-md">Присоединяйтесь к сообществу профессиональных инвесторов и вкладывайте в реальный сектор экономики с доходностью до 25% годовых.</p>
              
              <div className="grid grid-cols-2 gap-8 pt-8 border-t border-white/10">
                <div>
                  <p className="text-3xl font-bold text-white">1.2M+</p>
                  <p className="text-sm text-[#64748B]">Активных инвесторов</p>
                </div>
                <div>
                  <p className="text-3xl font-bold text-emerald-400">18.5%</p>
                  <p className="text-sm text-[#64748B]">Средний годовой ROI</p>
                </div>
              </div>
            </div>
          </div>

          <div className="relative z-10 flex items-center gap-4 p-6 bg-white/5 border border-white/10 rounded-3xl backdrop-blur-md">
            <div className="w-12 h-12 rounded-full bg-orange-500/20 flex items-center justify-center text-orange-400 shrink-0">
              <ShieldCheck size={24} />
            </div>
            <p className="text-sm text-[#94A3B8] leading-snug">Ваши средства защищены по стандарту <span className="text-white font-bold">ISO 27001</span> и застрахованы на полную сумму вклада.</p>
          </div>
        </div>

        {/* Right Side: Form */}
        <div className="w-full lg:w-1/2 p-8 lg:p-16 flex flex-col justify-center bg-[#0F111A]/40">
          <div className="max-w-md mx-auto w-full">
            <div className="mb-10 text-center lg:text-left">
              <h1 className="text-3xl font-bold text-white mb-3">Авторизация</h1>
              <p className="text-[#64748B]">Введите свои учетные данные для входа в кабинет</p>
            </div>

            <form onSubmit={handleSubmit(onSubmit)} className="space-y-6">
              <div>
                <Input
                  label="Электронная почта"
                  placeholder="email@example.com"
                  icon={<Mail className="w-[18px]" />}
                  className={cn(error?.field === 'email' && "border-red-500 bg-red-500/5")}
                  {...register('email')}
                />
                <AnimatePresence>
                  {error?.field === 'email' && (
                    <motion.p initial={{ opacity: 0, y: -10 }} animate={{ opacity: 1, y: 0 }} className="text-red-400 text-xs mt-2 flex items-center gap-1">
                      <Lock size={12} /> {error.message}
                    </motion.p>
                  )}
                </AnimatePresence>
              </div>

              <div>
                <div className="relative">
                  <Input
                    label="Пароль"
                    type={showPassword ? 'text' : 'password'}
                    placeholder="••••••••"
                    icon={<Lock className="w-[18px]" />}
                    className={cn(error?.field === 'password' && "border-red-500 bg-red-500/5")}
                    {...register('password')}
                  />
                  <button
                    type="button"
                    onClick={() => setShowPassword(!showPassword)}
                    className="absolute right-4 top-[38px] text-[#64748B] hover:text-[#38BDF8]"
                  >
                    {showPassword ? <EyeOff className="w-5 h-5" /> : <Eye className="w-5 h-5" />}
                  </button>
                </div>
                <AnimatePresence>
                  {error?.field === 'password' && (
                    <motion.p initial={{ opacity: 0, y: -10 }} animate={{ opacity: 1, y: 0 }} className="text-red-400 text-xs mt-2 flex items-center gap-1">
                      <Lock size={12} /> {error.message}
                    </motion.p>
                  )}
                </AnimatePresence>
              </div>

              <div className="grid grid-cols-2 gap-4 items-end">
                <Input
                  label="Проверка (капча)"
                  placeholder="Код"
                  className={cn(error?.field === 'captcha' && "border-red-500")}
                  {...register('captcha')}
                />
                <div className="flex items-center gap-2 mb-0.5">
                  <div 
                    onClick={generateCaptcha}
                    className="h-11 flex-1 bg-[#1E293B] border border-[#334155] rounded-xl flex items-center justify-center font-mono text-xl font-bold tracking-widest text-[#38BDF8] cursor-pointer hover:border-[#38BDF8]/50 select-none italic"
                    style={{ textDecoration: 'line-through', textDecorationThickness: '2px' }}
                  >
                    {captchaCode}
                  </div>
                </div>
              </div>
              {error?.field === 'captcha' && <p className="text-red-400 text-xs mt-1">{error.message}</p>}

              <div className="flex items-center justify-between pt-2">
                <label className="flex items-center gap-2 cursor-pointer group">
                  <input type="checkbox" className="sr-only peer" {...register('rememberMe')} />
                  <div className="w-5 h-5 border-2 border-[#475569] rounded-md peer-checked:bg-[#38BDF8] peer-checked:border-[#38BDF8] transition-all" />
                  <span className="text-sm text-[#94A3B8] group-hover:text-[#F1F5F9] transition-colors">Запомнить</span>
                </label>
                <Link to="/reset-password" className="text-sm text-[#38BDF8] hover:underline font-medium">Забыли пароль?</Link>
              </div>

              {error?.field === 'general' && (
                <div className="bg-red-500/10 border border-red-500/20 rounded-xl p-3 text-red-400 text-sm">{error.message}</div>
              )}

              <Button type="submit" className="w-full h-14 text-lg" isLoading={isLoading}>
                Войти в кабинет <ArrowRight className="ml-2 w-5 h-5" />
              </Button>
            </form>

            <div className="mt-10 pt-8 border-t border-white/5 text-center">
              <p className="text-[#64748B] text-sm">
                Впервые у нас?{' '}
                <Link to="/register" className="text-[#38BDF8] font-bold hover:underline">Создать аккаунт</Link>
              </p>
            </div>
          </div>
        </div>
      </motion.div>
    </div>
  );
};
